{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "strictNullChecks": false,
    "target": "esnext",
    "paths": {
      "$lib": ["./src"],
      "$lib/*": ["./src/*"]
    },
    "baseUrl": ".",
    "rootDir": "."
  },
  "exclude": ["**/*.spec.ts"],
  "include": ["./src/**/*", "./*.ts"]
}
